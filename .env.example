# Copy this file to schedule-be/.env and fill in real values before running
# `docker compose up --build`.

NODE_ENV=production
PORT=3000

# Database — DB_HOST is overridden to "postgres" (container name) by docker-compose
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change_me_in_production
DB_NAME=scheduler

# JWT — replace with strong random secrets (min 32 chars)
JWT_SECRET=replace_with_a_strong_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_strong_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# The URL the backend will accept CORS requests from
FRONTEND_URL=http://localhost:8080
